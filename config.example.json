        "home_to_airport_ride_min": 60,
        "default_ride_min": 60,
        "deplane_to_curb_min": 30,
        "arrival_cushion_min": 90,
        "layover_max_min": 240,
        "layover_ambiguous_max_min": 360,
        "ground_transport_mode": "Uber"
      },
      "lodging": {
        "default_checkin_time": "16:00",
        "default_checkout_time": "11:00"
      }
    }
  }
